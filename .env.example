# Copy to .env and fill in.
# PIVX mainnet address that receives payments. MUST be one you control.
PIVX_PAY_TO=DPfAPDnN6kyCb2qCx4tbjBks23dBNHLGsL

# Price per cat picture, in PIV.
PRICE_PIV=0.0001

# Network: mainnet | testnet | regtest. Explorer backend only supports
# mainnet/testnet (regtest is private to one machine).
PIVX_NETWORK=mainnet

# BlockBook-compatible explorer. Override if you run your own.
# blockbook.pivx.org disappeared in May 2026; explorer.duddino.com is
# currently the most reliable public BlockBook mirror for PIVX mainnet.
PIVX_EXPLORER_URL=https://explorer.duddino.com

# Confirmations required before the payment unlocks the resource.
MIN_CONFIRMATIONS=1

# Scheme: pivx-transparent | pivx-shield (shield requires a node, not an explorer).
SCHEME=pivx-transparent

# Host-side port. Apache reverse-proxies to this.
HOST_PORT=4403
